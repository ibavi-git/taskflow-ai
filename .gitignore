# ============================================
# TaskFlow AI - Production .gitignore
# ============================================

# Root & Build Logs
/build.log
*.log
*.err
*.out
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Backend (Spring Boot / Maven)
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
backend/.idea/
backend/*.iml
backend/.classpath
backend/.project
backend/.settings/
backend/logs/
backend/*.log
backend/*.out
backend/application-local.yml
backend/application-local.properties

# Backend Local Environments
backend/.env
backend/.env.*
!backend/.env.example

# Frontend (React / Vite / Node)
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.cache/
frontend/*.log
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*

# Frontend Local Environments
frontend/.env
frontend/.env.*
!frontend/.env.example

# Docker & Databases
docker-data/
postgres_data/
/postgres_data/
*.pid
docker-compose.override.yml

# IDE & Code Editors
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
*.iml
*.sublime-project
*.sublime-workspace

# Operating System Junk
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/
ehthumbs.db
Icon?
ehthumbs_vista.db

# Java & Compilation
*.class
*.jar
*.war
*.ear
hs_err_pid*
replay_pid*

# Maven specific
.mvn/timing.properties

# Build & Test outputs
build/
out/
coverage/
test-results/
playwright-report/
*.lcov

# Temporary / Cache files
*.tmp
*.temp
*.swp
*.swo
*~
.sass-cache/

# Archives
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# Generated Reports & Media
reports/
screenshots/
/reports/
/screenshots/

# AI / Agents Config
.agents/
attached_assets/

# Root Environment files
.env
.env.*
!.env.example