# ============================================
# TaskFlow AI - Backend Environment Template
# ============================================

# Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/taskflow_db
SPRING_DATASOURCE_USERNAME=your_database_user
SPRING_DATASOURCE_PASSWORD=your_database_password

# JPA/Hibernate Configuration
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true

# Server Configuration
SERVER_PORT=8080
SPRING_APPLICATION_NAME=taskflow-api
SPRING_PROFILES_ACTIVE=dev

# Google Gemini API Configuration (MAIN AI SERVICE)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models/
GEMINI_API_MODEL_ID=gemini-2.5-flash

# Google Calendar Integration (Optional)
GOOGLE_CALENDAR_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
GOOGLE_CALENDAR_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8080/auth/google/callback

# CORS Configuration (comma-separated, no spaces)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT & Security (Secret must be at least 32 bytes/characters long)
JWT_SECRET=your_jwt_secret_key_at_least_32_characters_long
JWT_EXPIRATION_MS=86400000

# Logging Configuration (optional)
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_TASKFLOW=DEBUG