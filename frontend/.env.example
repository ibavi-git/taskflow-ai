# ============================================
# TaskFlow AI - Frontend Environment Variables
# ============================================
# INSTRUCTIONS: Copy this file to frontend/.env.local

# Backend API Configuration
VITE_API_BASE_URL=http://localhost:8080/api
VITE_API_TIMEOUT=30000

# Feature Flags
VITE_ENABLE_CALENDAR_SYNC=true
VITE_ENABLE_GEMINI_AI=true

# Google OAuth (if using Google Calendar integration)
VITE_GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# App Configuration
VITE_APP_TITLE=TaskFlow AI
VITE_APP_ENV=development

# ============================================
# For Production, use .env.production:
# ============================================
# VITE_API_BASE_URL=https://taskflow-api.onrender.com/api
# VITE_APP_ENV=production
